PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
DB_PATH=./data/stealth.db

# Redis — required for BullMQ retries & queue metrics (optional, falls back gracefully)
REDIS_URL=redis://127.0.0.1:6379

# BullMQ concurrency — max parallel tasks (default: 3)
QUEUE_CONCURRENCY=3

# Profiles — where browser session folders are stored (default: ./data/profiles)
PROFILES_DIR=./data/profiles

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require JWT tokens for all API endpoints.
# Default credentials: admin / admin123  — CHANGE THESE IN PRODUCTION!
AUTH_ENABLED=false
JWT_SECRET=stealth-browser-dev-secret-change-in-production
JWT_EXPIRES=24h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Max run requests per IP per minute (default: 30)
RATE_LIMIT_RUNS=30
# Max general API requests per IP per minute (default: 300)
RATE_LIMIT_API=300

# ─── Proxy Pool Rotation ──────────────────────────────────────────────────────
# Comma-separated proxy URLs for round-robin rotation.
# Leave empty to disable proxy rotation.
# PROXY_POOL=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
